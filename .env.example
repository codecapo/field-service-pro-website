# Live demo of the field PWA embedded in the mobile mockups.
# Point at a NO-LOGIN demo deployment of apps/field (built WITHOUT Supabase env
# so it boots into seeded demo data). Leave blank to use the static screens.
NEXT_PUBLIC_DEMO_APP_URL=

# --- Contact form email (Resend) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=
# Where demo requests are delivered (defaults to site.email = hello@havenams.com).
CONTACT_TO_EMAIL=rez@havenams.com
# Verified sender. Until your domain is verified in Resend, use
# "Haven AMS <onboarding@resend.dev>" for testing. For production, verify
# havenams.com in Resend and use e.g. "Haven AMS <noreply@havenams.com>".
CONTACT_FROM_EMAIL=Haven AMS <noreply@havenams.com>
